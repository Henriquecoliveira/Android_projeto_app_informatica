<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CheckoutFragment">

    <LinearLayout
        android:id="@+id/formContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/firstCardProduct"
            android:layout_width="match_parent"
            android:layout_height="228dp"
            app:srcCompat="@drawable/a520m" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Falta pouco para finalizar sua compra!"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forma de pagamento"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerPagamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="CEP"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/endereco_Confirmacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex.: 136182-204"
            android:inputType="text" />

        <Button
            android:id="@+id/confirmar_Confirmacao"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:textSize="18sp"
            android:background="@drawable/rounded_12px"
            android:text="Confirmar" />

    </LinearLayout>

</ScrollView>